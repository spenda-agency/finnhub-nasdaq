# Finnhub APIキー（無料登録: https://finnhub.io/register）
FINNHUB_API_KEY=your_finnhub_api_key_here

# Slack Bot Token（xoxb-で始まる）
# 必須スコープ: chat:write, files:write
# 任意スコープ: channels:read（チャンネル名→ID自動解決に必要。IDを直接指定するなら不要）
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack投稿先チャンネル
# 推奨: チャンネルID（C... 形式）を直接指定（最も確実）
# 例: SLACK_CHANNEL=C05QPTXN4HE
# チャンネル名 (#foo) でも可だが、Botに channels:read スコープが必要
SLACK_CHANNEL=C05QPTXN4HE

# Anthropic Claude API（コラム記事生成・X投稿文生成用）
# https://console.anthropic.com/settings/keys で発行
ANTHROPIC_API_KEY=sk-ant-...

# WordPress 連携（X投稿下書き保存用）
# WP_SITE_URL: サイトのルートURL（末尾 / は不要）
# WP_USERNAME: WordPress のログインユーザー名
# WP_APP_PASSWORD: アプリケーションパスワード
#   WP管理画面 → ユーザー → プロフィール → 「アプリケーションパスワード」セクションで発行
#   （スペースは入れたままコピペでOK、内部で処理される）
WP_SITE_URL=https://fxstock-dataincome.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
